DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
JWT_SECRET_KEY=your_super_secret_jwt_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
# Email (Gmail SMTP for OTPs)
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
FLASK_ENV=development
FLASK_DEBUG=1

# Google OAuth (console.cloud.google.com → Credentials → OAuth 2.0 Client IDs)
# Authorized redirect URI: http://localhost:5000/api/auth/google-oauth/google/authorized
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email OTP — any random 32-char string
OTP_SECRET_KEY=change_this_to_a_random_32_char_string

# Frontend URL for OAuth redirect (no trailing slash)
FRONTEND_URL=http://localhost:5173

